# CodePen GraphQL API (https://codepen.io/graphql)
# Get these from browser DevTools when logged in at codepen.io

# Internal user ID (from PensPaginatedGridQuery variables: filters.userId)
CODEPEN_USER_ID=

# Session cookie (cp_session from Application > Cookies)
CODEPEN_SESSION=

# CSRF token (x-csrf-token header from any GraphQL request)
CODEPEN_CSRF_TOKEN=

# Optional: output path (default: src/data/pens.json)
# PENS_OUTPUT_PATH=src/data/pens.json
