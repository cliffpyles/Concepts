# Concepts - CodePen sync
# CodePen GraphQL API (https://codepen.io/graphql)
# Get these from browser DevTools when logged in at codepen.io

# Optional: user ID (auto-fetched from session if not set)
# CODEPEN_USER_ID=

# Session cookie (cp_session from Application > Cookies)
CODEPEN_SESSION=

# CSRF token (x-csrf-token header from any GraphQL request)
CODEPEN_CSRF_TOKEN=

# Optional: Cloudflare cookies (cf_clearance, __cf_bm) - copy from DevTools if requests fail
# CODEPEN_CF_CLEARANCE=
# CODEPEN_CF_BM=

# Optional: debug mode - set to 1 to log raw API response when 0 pens returned
# CODEPEN_DEBUG=0

# Optional: output path (default: src/data/pens.json)
# PENS_OUTPUT_PATH=src/data/pens.json
